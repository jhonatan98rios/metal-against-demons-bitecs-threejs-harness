{
  "name": "metal-against-demons-bitecs-threejs-harness",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "harness": "tsx tools/harness/index.ts",
    "imports": "madge src --circular",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "depcruise": "depcruise src --config dependency-cruiser.mjs",
    "knip": "knip --reporter json",
    "complexity": "lizard src -C6 -L30",
    "format:check": "pnpm prettier --check .",
    "format": "pnpm  prettier --write .",
    "validate": "pnpm lint && pnpm typecheck && pnpm test",
    "validate:full": "pnpm validate && pnpm depcruise && pnpm knip && pnpm complexity && pnpm format && pnpm format:check"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-functional": "^9.0.5",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "knip": "^6.14.2",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "prettier": {
    "printWidth": 80,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  }
}
