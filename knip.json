{
  "$schema": "https://unpkg.com/knip@latest/schema.json",

  "entry": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "tools/**/*.ts",
    "next.config.*"
  ],

  "project": ["**/*.{ts,tsx,js,mjs}"],

  "ignore": [".next/**", "dist/**", "coverage/**"],

  "ignoreDependencies": [
    "@types/node",
    "@types/react",
    "@types/react-dom",
    "eslint",
    "prettier",
    "tailwindcss"
  ],

  "ignoreBinaries": ["lizard"],

  "eslint": {
    "config": ["eslint.config.mjs"]
  },

  "typescript": {
    "config": ["tsconfig.json"]
  },

  "next": true
}
